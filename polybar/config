[global/wm]
include-file = "/home/ettore/.config/polybar/colors.ini"


[settings]


[color]
trasparent = #00000000

[bar/dummy_top]
bottom=false
width=100%
height = 40
modules-left = 
modules-center = dummy
modules-right =
background = ${color.trasparent}
foreground = ${color.trasparent}
#wm-restack = i3


[bar/top]
font-0 = "Cascadia Mono PL:pixelsize=13;3"
font-1 = "FontAwesome:pixelsize=13;3"

bottom=false
background = ${color.background}
foreground = ${color.foreground}
modules-left = launcher workspaces title
modules-center = time
modules-right = updates updates_trigger backlight volume iface battery powermenu
padding = 0
width = 100%:-20
height = 30
fixed-center = true
override-redirect = true
offset-x = 10
offset-y = 10
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
#wm-restack = i3


[module/launcher]
type=custom/text
content="ÔÄā"
content-padding = 2
click-left = /home/ettore/.config/i3/scripts/launcher.sh
click-right = /home/ettore/.config/i3/scripts/settings/color-switch.sh
content-background = ${color.shade1}
content-foreground = ${color.background}

[module/workspaces]
type=internal/i3
pin-workspaces = true
enable-click = true
label-focused = ÔĄĎ
label-focused-padding = 1
label-focused-foreground = ${color.background}
label-focused-background = ${color.shade2}

label-occupied = ÔÜí
label-occupied-padding = 1
label-occupied-foreground = ${color.background}
label-occupied-background = ${color.shade2}

#label-empty = X
#label-empty-padding = 1
#label-empty-foreground = ${color.background}
#label-empty-background = ${color.shade2}

label-unfocused = ÔĄĆ
label-unfocused-padding = 1
label-unfocused-foreground = ${color.background}
label-unfocused-background = ${color.shade2}

label-urgent = ÔĀ™
label-urgent-padding = 1
label-urgent-foreground = ${color.background}
label-urgent-background = ${color.shade2}

label-mode-background = ${color.shade2}
label-mode-foreground = ${color.background}
label-mode-padding = 1

format = <label-state><label-mode>

[module/title]
type = internal/xwindow
; Available tags:
;   <label> (default)
format = <label>
format-background = ${color.shade3}
format-foreground = ${color.background}
format-padding = 1

; Available tokens:
;   %title%
; Default: %title%
label = ÔĄ§ %title:0:17:...% %{A1:i3-msg kill:}ÔĀó%{A} 

; Used instead of label when there is no window title
; Available tokens:
;   None
label-empty = 


[module/cpu]
type = internal/cpu
interval = 2
format = Ôčõ <label>
label-minlen = 4
format-padding = 1
format-foreground = ${color.background}
format-background = ${color.shade4}


[module/updates]
type = custom/ipc
hook-0 = /home/ettore/.config/i3/scripts/packages
format = <output>
format-padding = 1
format-foreground = ${color.background}
format-background = ${color.shade6}
click-left = termite --exec="yay -Syyu" && polybar-msg hook updates 1

[module/updates_trigger]
type=custom/script
exec=polybar-msg hook updates 1
interval=300
label=

[module/backlight]
type = internal/backlight
card = intel_backlight
enable-scroll = true
format = ÔÉę <label>
format-padding = 1
format-background = ${color.shade5}
format-foreground = ${color.background}
label = %percentage%%
label-minlen = 4

[module/volume]
type = internal/pulseaudio
format-volume = <ramp-volume> <label-volume>
format-volume-padding = 1
format-volume-background = ${color.shade4}
format-volume-foreground = ${color.background}
label-volume-minlen = 4
label-muted = ÔÄć Muted
label-muted-foreground = ${color.background}
label-muted-background = ${color.shade4}
label-muted-padding = 1
ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®
click-right = pavucontrol

[module/iface]
type=custom/script
exec=/home/ettore/.config/i3/scripts/iface
interval=5
click-left=/home/ettore/.config/i3/scripts/wifi_menu.sh
format-padding = 1
format-background = ${color.shade3}
format-foreground = ${color.background}

[module/battery]
type=internal/battery
format-charging = <animation-charging> <label-charging>
format-charging-padding = 1
format-charging-foreground = ${color.background}
format-charging-background = ${color.shade2}
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-padding = 1
format-discharging-foreground = ${color.background}
format-discharging-background = ${color.shade2}
format-full = <ramp-capacity> <label-full>
format-full-padding = 1
format-full-foreground = ${color.background}
format-full-background = ${color.shade2}
label-charging-minlen = 4
label-discharging-minlen = 4
label-full-minlen = 4
label-charging = %percentage%%
label-discharging = %percentage%%
label-full = %percentage%%
ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ
animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750


[module/powermenu]
type=custom/text
content = "ÔÄĎ"
content-padding = 2
click-left = /home/ettore/.config/i3/scripts/powermenu.sh
content-background = ${color.shade1}
content-foreground = ${color.background}

[module/time]
type=internal/date
interval = 1.0
time = %H:%M
date = %b %d %Y
format = <label>
label = ÔĄ≥ %date%  ÔÄó %time%

