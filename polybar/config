[global/wm]

[settings]


[colors]
;background = #ffdd20
;active-background = #ffcc20
;foreground = #775520
;active-foreground = #664410
trasparent = #00000000
background = #2a2010
foreground = #fff0cc
active = #ffd065
accent-0 = #ff9033
accent-1 = #ffa033
accent-2 = #ffb033
accent-3 = #ffc033
accent-4 = #ffd033
accent-5 = #fff033


[bar/dummy_top]
bottom=false
width=100%
height = 40
modules-left = 
modules-center = dummy
modules-right =
background = ${colors.trasparent}
foreground = ${colors.trasparent}

[bar/top]
font-0 = "Cascadia Mono PL:pixelsize=13;3"
font-1 = "FontAwesome:pixelsize=13;3"

bottom=false
background = ${colors.background}
foreground = ${colors.foreground}
modules-left = launcher workspaces
modules-center = time
modules-right = updates updates_trigger backlight volume iface battery powermenu
padding = 0
width = 100%:-20
height = 30
fixed-center = true
override-redirect = true
offset-x = 10
offset-y = 10
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true


[module/launcher]
type=custom/text
content="ÔÄā"
content-padding = 1
click-left = /home/ettore/.config/i3/scripts/launcher.sh
#click-right = /home/ettore/.config/i3/scripts/change_color.sh
content-background = ${colors.accent-0}
content-foreground = ${colors.background}

[module/workspaces]
type=internal/i3
pin-workspaces = true
enable-click = true
label-focused = ÔĄĎ
label-focused-padding = 1
label-focused-foreground = ${colors.background}
label-focused-background = ${colors.accent-1}

label-occupied = ÔÜí
label-occupied-padding = 1
label-occupied-foreground = ${colors.background}
label-occupied-background = ${colors.accent-1}

label-unfocused = ÔĄĆ
label-unfocused-padding = 1
label-unfocused-foreground = ${colors.background}
label-unfocused-background = ${colors.accent-1}

label-urgent = ÔĀ™
label-urgent-padding = 1
label-urgent-foreground = ${colors.background}
label-urgent-background = ${colors.accent-1}

label-mode-background = ${colors.accent-2}
label-mode-foreground = ${colors.background}
label-mode-padding = 1

format = <label-state><label-mode>

[module/updates]
type = custom/ipc
hook-0 = /home/ettore/.config/i3/scripts/packages
format = <output>
format-padding = 1
format-foreground = ${colors.background}
format-background = ${colors.accent-5}
click-left = termite --exec="yay -Syyu" && polybar-msg hook updates 1

[module/updates_trigger]
type=custom/script
exec=polybar-msg hook updates 1
interval=300
label=

[module/backlight]
type = internal/backlight
card = intel_backlight
enable-scroll = true
format = ÔÉę <label>
format-padding = 1
format-background = ${colors.accent-4}
format-foreground = ${colors.background}
label = %percentage%%
label-minlen = 4

[module/volume]
type = internal/pulseaudio
format-volume = <ramp-volume> <label-volume>
format-volume-padding = 1
format-volume-background = ${colors.accent-3}
format-volume-foreground = ${colors.background}
label-volume-minlen = 4
label-muted = ÔÄć Muted
label-muted-foreground = ${colors.background}
label-muted-background = ${colors.accent-3}
label-muted-padding = 1
ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®
click-right = pavucontrol

[module/iface]
type=custom/script
exec=/home/ettore/.config/i3/scripts/iface
interval=5
click-left=/home/ettore/.config/i3/scripts/wifi_menu.sh
format-padding = 1
format-background = ${colors.accent-2}
format-foreground = ${colors.background}

[module/battery]
type=internal/battery
format-charging = <animation-charging> <label-charging>
format-charging-padding = 1
format-charging-foreground = ${colors.background}
format-charging-background = ${colors.accent-1}
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-padding = 1
format-discharging-foreground = ${colors.background}
format-discharging-background = ${colors.accent-1}
format-full = <ramp-capacity> <label-full>
format-full-padding = 1
format-full-foreground = ${colors.background}
format-full-background = ${colors.accent-1}
label-charging-minlen = 4
label-discharging-minlen = 4
label-full-minlen = 4
label-charging = %percentage%%
label-discharging = %percentage%%
label-full = %percentage%%
ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ
animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750


[module/powermenu]
type=custom/text
content = " ÔÄĎ "
click-left = /home/ettore/.config/i3/scripts/powermenu.sh
content-background = ${colors.accent-0}
content-foreground = ${colors.background}

[module/time]
type=internal/date
interval = 1.0
time = %H:%M
date = %b %d %Y
format = <label>
label = ÔĄ≥ %date%  ÔÄó %time%

[module/dummy]
type=custom/text
content=" "
