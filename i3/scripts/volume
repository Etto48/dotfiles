MUTED=$(pulseaudio-ctl full-status | awk '{ printf "%s", $2 }')
LEVEL=$(pulseaudio-ctl full-status | awk '{ printf "%i", $1 }')

if [[ "${MUTED}" = "yes" ]]; then
  echo "´Çª Mute"
else
  if [[ "${LEVEL}" -ge "50" ]]; then
    echo -n "´Ç¿"
  elif [[ "${LEVEL}" -ge "1" ]]; then
    echo -n "´Çº"
  else
    echo -n "´Çª"
  fi
  echo " ${LEVEL}%"
fi

